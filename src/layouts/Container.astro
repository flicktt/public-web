---
interface Props extends astroHTML.JSX.HTMLAttributes {
  section?: boolean;
}

const { section, ...props } = Astro.props;
const _props = { ...props };
if (_props) delete _props.class;

const classes = "max-w-section px-6 lg:px-12 m-auto";
---

{
  section ? (
    <section {..._props} class:list={[classes, props.class]}>
      <slot />
    </section>
  ) : (
    <div {..._props} class:list={[classes, props.class]}>
      <slot />
    </div>
  )
}
