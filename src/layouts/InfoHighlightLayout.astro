---
interface Props {
  title: string;
  size?: "md" | "full";
  sectionProps?: astroHTML.JSX.HTMLAttributes;
}

const { title, size = "full", sectionProps } = Astro.props;
const _sectionProps = { ...sectionProps };
if (_sectionProps) delete _sectionProps.class;
---

<section
  {..._sectionProps}
  class:list={[
    "flex flex-col bg-white/5 p-10 gap-2 rounded-xl text-xl",
    {
      "m-auto w-full max-w-4xl": size === "md",
    },
    sectionProps?.class,
  ]}
>
  <h4 class="text-flick-yellow font-bold text-4xl">{title}</h4>
  <slot />
</section>
