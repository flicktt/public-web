---
import XMark from "../../../icons/XMark.svg";

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<dialog
  id={id}
  class="fixed inset-0 ml-auto flex flex-col justify-between max-h-none h-screen max-w-150 bg-flick-black text-white backdrop:backdrop-brightness-50 backdrop:backdrop-blur-xs not-open:translate-x-full open:translate-x-0 transition-transform"
  closedby="any"
>
  <button
    class="w-fit flex self-end cursor-pointer p-1"
    commandfor={id}
    command="close"
  >
    <XMark class="size-10" />
  </button>
  <slot />
</dialog>
