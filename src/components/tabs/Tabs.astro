---
import Tab from "./Tab.astro";

interface Props {
  containerProps?: astroHTML.JSX.HTMLAttributes;
  tabProps?: astroHTML.JSX.ButtonHTMLAttributes;
}

let _containerProps: astroHTML.JSX.HTMLAttributes = {};
const { containerProps, tabProps } = Astro.props;
if (containerProps) {
  _containerProps = { ...containerProps };
  delete _containerProps.class;
}

const tabConfig = [
  { label: "Group sessions", hash: "#group-sessions" },
  { label: "1-2-1s", hash: "#one-to-ones" },
  { label: "Workshops", hash: "#workshops" },
  { label: "Open sessions", hash: "#open-sessions" },
  { label: "Table bookings", hash: "#table-bookings" },
  { label: "Corporate", hash: "#corporate" },
];
---

<div class="border-b border-flick-dark overflow-x-auto">
  <div
    {..._containerProps}
    class:list={[
      "flex flex-row flex-wrap lg:flex-nowrap w-full m-auto border-x border-flick-dark",
      containerProps?.class,
    ]}
  >
    {
      tabConfig.map(({ label, hash }) => (
        <Tab hash={hash} buttonProps={tabProps}>
          {label}
        </Tab>
      ))
    }
  </div>
</div>
<div>
  {
    tabConfig.map(({ label, hash }) => (
      <div class="tab-content hidden" id={hash.slice(1)}>
        {label + " content"}
      </div>
    ))
  }
</div>

<script>
  document.addEventListener("click", (e) => {
    let el = e.target as HTMLAnchorElement;
    if (el?.classList.contains("tab-links")) {
      let activeContent = document.querySelector(".tab-content.block");
      if (activeContent) {
        activeContent.classList.remove("block");
        activeContent.classList.add("hidden");
      }

      let activeTab = document.querySelector(".tab-links.bg-red-950");
      if (activeTab) activeTab.classList.remove("bg-red-950");

      el.classList.add("bg-red-950");
      let tabTarget = document.querySelector(el.dataset.target as string);
      tabTarget?.classList.add("block");
      tabTarget?.classList.remove("hidden");
      window.location.hash = el.dataset.target ?? "";
    }
  });

  const openTarget = location.hash ? location.hash : "#group-sessions";
  const tabContent = document.querySelector(openTarget);
  tabContent?.classList.add("block");
  tabContent?.classList.remove("hidden");

  const tab = document.querySelector("[data-target='" + openTarget + "']");
  tab?.classList.add("bg-red-950");
</script>
