---
import HeaderContainer from "./HeaderContainer.astro";

type HeaderConfig = {
  title: string;
};

const { page } = Astro.props;

const headerConfig: Record<string, HeaderConfig> = {
  offerings: {
    title: "Offerings",
  },
  compete: {
    title: "Compete",
  },
  kids: {
    title: "Kids",
  },
  membership: {
    title: "Membership",
  },
  about: {
    title: "About",
  },
  coaches: {
    title: "Coaches",
  },
};
---

<HeaderContainer>
  <h1 class="font-extrabold text-[250px] uppercase text-flick-yellow">
    {headerConfig[page]?.title}
  </h1>
</HeaderContainer>
