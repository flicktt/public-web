---
const links = [
  { name: "Offerings", link: "/" },
  { name: "Compete", link: "/" },
  { name: "Kids", link: "/" },
  { name: "Membership", link: "/" },
  // { name: "Blog", link: "/" },
  { name: "About", link: "/" },
];
---

<nav class="w-full">
  <ul class="flex flex-row gap-10 justify-end text-white">
    {
      links.map(({ name, link }) => (
        <li>
          <a href={link}>{name}</a>
        </li>
      ))
    }
  </ul>
</nav>
