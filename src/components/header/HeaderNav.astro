---
import NavLogo from "../../assets/logo-no-sub.svg";

const { page } = Astro.props;

const links = [
  { name: "Offerings", link: "/offerings" },
  { name: "Compete", link: "/compete" },
  { name: "Kids", link: "/kids" },
  { name: "Membership", link: "/membership" },
  { name: "About", link: "/about" },
];

const isHome = page === "home";
---

<nav class="w-full px-3">
  <div
    class={`flex ${isHome ? "justify-end" : "justify-between"} items-center h-12.5`}
  >
    {
      !isHome && (
        <a href="/">
          <NavLogo height="50px" />
        </a>
      )
    }
    <ul class="flex flex-row gap-10 text-white">
      {
        links.map(({ name, link }) => (
          <li>
            <a href={link}>{name}</a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
