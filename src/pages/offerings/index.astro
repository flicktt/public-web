---
import PageHeader from "../../components/header/PageHeader.astro";
import Tabs from "../../components/tabs/Tabs.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Offerings">
  <PageHeader page="offerings" />
  <Tabs
    containerProps={{
      class: "max-w-full sm:max-w-120.5 lg:max-w-fit",
    }}
    tabProps={{
      class:
        "not-last-of-type:border-b sm:not-last-of-type:border-b-0 sm:nth-of-type-[-n+3]:border-b lg:sm:nth-of-type-[-n+3]:border-b-0",
    }}
  />
</Layout>
