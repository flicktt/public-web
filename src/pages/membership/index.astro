const pricingConfig = {
  normal: [
    { label: "Group session", price: "£20" },
    { label: "Open session", price: "£20" },
    { label: "Private Coaching lesson", price: "£60" },
    { label: "Workshop", price: "N/A" },
    { label: "Flick TT League season membership", price: "£65" },
