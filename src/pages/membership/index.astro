---
import PointsRow from "../../components/pointsRow/PointsRow.astro";
import Button from "../../components/ui/inputs/Button.astro";
import Container from "../../layouts/Container.astro";
import PageLayout from "../../layouts/PageLayout.astro";
import PercentBadge from "../../icons/PercentBadge.svg";
